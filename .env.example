
#U
U_MODEL_SOURCE=modelscope
MODELSCOPE_OFFLINE=1
MODELSCOPE_CACHE=F:/docker/modelscope_cache
HF_HOME=F:/docker/huggingface_cache
MD_ROOT_DIR=./temp-files/

#基础模型
LLM_DEFAULT_MODEL=deepseek-v4-pro
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
LLM_DEFAULT_TEMPERATURE=0.1
#多模态模型
VL_MODL=wan2.7-image-pro
VL_MODEL_API_KEY=your-vl-api-key-here
VL_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1



# Milvus 配置
MILVUS_URL=http://127.0.0.1:19530
# 存储切片集合
CHUNKS_COLLECTION=kaas_chunks
# 存储每个文档对应的实体类
ITEM_NAME_COLLECTION=kaas_item_names

EMBEDDING_DIM=1024


# Neo4j 配置（如果已启动的话）
NEO4J_URI=bolt://192.168.11.104:7687
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

#Mongodb的配置
MONGO_URL=mongodb://root:123456@127.0.0.1:27017/?authSource=admin
MONGO_DB_NAME=kaas

# MySQL 配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=kaas_rag

#minio客户端
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=knowledge-base-files
MINIO_IMG_DIR=/upload-images
MINIO_SECURE=False

# reranker 远程服务（Docker 部署 bge-reranker-large）
RERANKER_BASE_URL=http://127.0.0.1:18081/v1
RERANKER_API_KEY=
RERANKER_MODEL_NAME=bge-reranker-large

# embedding模型远程服务（Docker 部署 BGE-M3）
EMBEDDING_BASE_URL=http://127.0.0.1:18088/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
ITEM_NAME_DIAG=1
EMBEDDING_USE_LOCAL=true
EMBEDDING_LOCAL_MODEL_PATH=F:/docker/models/bge-m3
EMBEDDING_USE_FP16=true
EMBEDDING_DEVICE=cpu

MCP_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/sse


# MinerU API 配置
MINERU_API_TOKEN=your-mineru-api-token
MINERU_BASE_URL=https://mineru.net/api/v4



# ===================== 日志配置 =====================
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO

# 日志配置
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
LOG_FILE_RETENTION=7 days
